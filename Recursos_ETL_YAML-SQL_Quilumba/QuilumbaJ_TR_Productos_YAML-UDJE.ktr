    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// ============================================================
// ENRIQUECIMIENTO DE CATÁLOGO — Staging Area BI
// Autor: Javier Quilumba | EPN — Business Intelligence GR2SW
// ============================================================

// Variables internas de cálculo (no se exportan)
var precio_num = parseFloat(String(unit_price).trim());
var qty_num    = parseInt(String(stock_quantity));

// 1. Precio limpio y valor total como String formateado
var precio                 = String(precio_num.toFixed(2));
var valor_total_inventario = String((precio_num * qty_num).toFixed(2));

// 2. Clasificación por precio
var clasificacion_precio;
if (precio_num > 500) {
    clasificacion_precio = "PREMIUM";
} else if (precio_num >= 100) {
    clasificacion_precio = "MID-RANGE";
} else {
    clasificacion_precio = "ECONOMICO";
}

// 3. Estado del stock
var estado_stock;
if (qty_num == 0) {
    estado_stock = "SIN STOCK";
} else if (qty_num &lt;= 20) {
    estado_stock = "CRITICO";
} else if (qty_num &lt;= 50) {
    estado_stock = "BAJO";
} else {
    estado_stock = "NORMAL";
}

// 4. Active: Java Boolean → texto
var estado_activo = String(active) == "true" ? "ACTIVO" : "INACTIVO";

// 5. Normalizar campos de texto
var categoria_norm = String(category).trim().toUpperCase();
var proveedor_norm = String(supplier_code).trim().toUpperCase();
var nombre_norm    = String(name).trim().toUpperCase();
</jsScript_script>
      </jsScript>
    </jsScripts>
